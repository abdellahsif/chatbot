# Required: Supabase connection (read-only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_readonly_anon_key

# Keep DB-first behavior (recommended)
SUPABASE_STRICT_MODE=1

# API port
APP_PORT=3001

# Keep current runtime behavior (latency-friendly)
USE_CROSS_ENCODER_RERANKER=0

# Retrieval / indexing tuning (optional)
# USE_HNSW_INDEX=1 uses approximate nearest neighbors (faster, slightly lower recall than flat search).
USE_HNSW_INDEX=1
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=128

# Candidate pool sizes (higher = better recall, more latency)
DENSE_RETRIEVE_MAX=60
SPARSE_RETRIEVE_MAX=80

# Model selection
GENERATOR_MODEL=Qwen/Qwen2.5-0.5B-Instruct
CROSS_ENCODER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# Chat generation tuning (for "humane" small-talk)
CHAT_DO_SAMPLE=1
CHAT_TEMPERATURE=0.75
CHAT_TOP_P=0.92
CHAT_TOP_K=50
CHAT_REPETITION_PENALTY=1.06
CHAT_MAX_NEW_TOKENS=140

# Optional: assistant display name (used for small-talk like "what's your name?")
ASSISTANT_NAME=School Advisor
